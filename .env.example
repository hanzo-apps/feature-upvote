# Upvote — environment contract.
# Copy to `.env` for local dev. On Hanzo Cloud the deploy pipeline injects these.
# Only VITE_-prefixed vars reach the browser (this is a static SPA — no server).

# --- Identity (Hanzo IAM / hanzo.id, OIDC PKCE) ---------------------------------
# The OIDC issuer. hanzo.id serves /.well-known + /v1/iam/* for the hanzo brand.
VITE_HANZO_IAM_URL=https://hanzo.id
# The IAM application (client) id, <org>-<app>. `hanzo-app` is the shared apps
# client; its redirect-URI list must allow this deploy's /auth/callback origin
# (see README → "Ambient IAM"). Deploy provisions a dedicated per-app client.
VITE_IAM_CLIENT_ID=hanzo-app
# Optional: override the PKCE redirect. Defaults to `${origin}/auth/callback`.
# VITE_HANZO_REDIRECT_URI=

# --- Data (Hanzo Base, IAM-native) ---------------------------------------------
# Browser-reachable Base data plane. The signed-in user's IAM token is forwarded
# as the bearer; Base enforces org isolation. Deploy injects the provisioned URL.
VITE_HANZO_BASE_URL=https://api.hanzo.ai
